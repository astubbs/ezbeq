#!/usr/bin/env bash
# Pull and run a PUBLISHED ezbeq image from GHCR. Use this to verify that
# an image pushed by CI or scripts/publish-image actually works — prod's
# behavior without needing prod hardware.
#
# No build happens — the image is pulled fresh from GHCR on every
# invocation (docker compose up --pull always --force-recreate).
#
# Container name is `ezbeq` (the base compose default), so it won't
# collide with `ezbeq-local` from scripts/run-local. It WILL collide on
# port 8080 if run-local is currently up — stop it first with
# `scripts/run-local --stop`.
#
# Usage:
#   scripts/run-published               # prompt for tag (default: demo)
#   scripts/run-published demo          # pull + run ghcr.io/<owner>/ezbeq:demo
#   scripts/run-published v1.2.3        # pull + run a specific version tag
#   scripts/run-published demo --detach # same, detached (no log tail)
#   scripts/run-published --stop        # stop and remove the container
#   scripts/run-published --help
set -euo pipefail
# shellcheck source=_lib.sh
source "$(dirname "${BASH_SOURCE[0]}")/_lib.sh"
cd "$DOCKER_DIR"

case "${1:-}" in
    -h|--help) ezbeq::print_help; exit 0 ;;
esac

ezbeq::require_docker
ezbeq::require_compose
[[ -f "$DOCKER_DIR/docker-compose.yaml" ]] || {
    echo "Error: docker-compose.yaml missing in $DOCKER_DIR" >&2; exit 1
}
ezbeq::load_env
ezbeq::resolve_config

# Parse tag arg + flags.
TAG=""
FOLLOW_LOGS=1
STOP=0
while (( $# )); do
    case "$1" in
        -d|--detach) FOLLOW_LOGS=0 ;;
        --stop) STOP=1 ;;
        -*)
            echo "Error: unknown option '$1'. Run with --help to see usage." >&2
            exit 2
            ;;
        *)
            if [[ -z "$TAG" ]]; then
                TAG="$1"
            else
                echo "Error: only one tag may be given (got '$TAG' and '$1')." >&2
                exit 2
            fi
            ;;
    esac
    shift
done

COMPOSE=(docker compose -f docker-compose.yaml)

if (( STOP )); then
    "${COMPOSE[@]}" down
    exit 0
fi

if [[ -z "$TAG" ]]; then
    [[ -t 0 ]] || {
        echo "Error: no tag given and stdin is not a TTY." >&2
        echo "       Pass a tag: scripts/run-published demo" >&2
        exit 2
    }
    read -r -p "Image tag [demo]: " TAG
    TAG="${TAG:-demo}"
fi

ezbeq::resolve_owner
export EZBEQ_TAG="$TAG"

echo "Image  : ghcr.io/${OWNER}/ezbeq:${EZBEQ_TAG}"
echo "Config : $EZBEQ_CONFIG"
echo "Port   : $EZBEQ_PORT"
echo

"${COMPOSE[@]}" up -d --pull always --force-recreate

if (( FOLLOW_LOGS )); then
    echo
    echo "Running at http://localhost:$EZBEQ_PORT  (Ctrl+C to detach from logs)"
    echo
    "${COMPOSE[@]}" logs -f
else
    echo
    echo "Running at http://localhost:$EZBEQ_PORT"
    echo "Logs: scripts/run-published   |   Stop: scripts/run-published --stop"
fi
