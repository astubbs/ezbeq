#!/usr/bin/env bash
# Build and run ezbeq from the local source tree (dev Dockerfile target).
# Loads optional configuration from docker/.env (copy .env.example if you
# need to override defaults).
#
# A re-invocation while the container is already running restarts it (via
# --force-recreate) so code/image changes always take effect.
#
# Usage:
#   scripts/run-local               # build + (re)start + follow logs
#   scripts/run-local --detach, -d  # build + (re)start detached; print URL
#   scripts/run-local --logs        # alias of the default (kept for habit)
#   scripts/run-local --rebuild     # force clean rebuild + follow logs
#   scripts/run-local --stop        # stop and remove the container
#   scripts/run-local --help        # show this message
#
# Ctrl+C while tailing logs detaches from the stream — the container keeps
# running. Use --stop to tear it down.
#
# Works regardless of the directory the script is invoked from.
set -euo pipefail
# shellcheck source=_lib.sh
source "$(dirname "${BASH_SOURCE[0]}")/_lib.sh"
cd "$DOCKER_DIR"

case "${1:-}" in
    -h|--help) ezbeq::print_help; exit 0 ;;
esac

ezbeq::require_docker
ezbeq::require_compose
[[ -f "$DOCKER_DIR/docker-compose.yaml" && -f "$DOCKER_DIR/docker-compose.dev.yaml" ]] || {
    echo "Error: compose files missing in $DOCKER_DIR" >&2; exit 1
}
ezbeq::load_env
ezbeq::resolve_config
ezbeq::resolve_git_info
export GIT_BRANCH GIT_SHA

echo "Source : $REPO_ROOT"
echo "Config : $EZBEQ_CONFIG"
echo "Port   : $EZBEQ_PORT"
echo "Branch : ${GIT_BRANCH:-unknown}"
echo "SHA    : ${GIT_SHA:-unknown}"

COMPOSE=(docker compose -f docker-compose.yaml -f docker-compose.dev.yaml)
UP_FLAGS=(--build --force-recreate)
FOLLOW_LOGS=1

case "${1:-}" in
    "" | --logs) ;;
    -d|--detach) FOLLOW_LOGS=0 ;;
    --rebuild) UP_FLAGS=(--build --no-cache --force-recreate) ;;
    --stop)
        "${COMPOSE[@]}" down
        exit 0
        ;;
    *)
        echo "Error: unknown option '$1'. Run with --help to see usage." >&2
        exit 2
        ;;
esac

"${COMPOSE[@]}" up -d "${UP_FLAGS[@]}"

if (( FOLLOW_LOGS )); then
    echo
    echo "Running at http://localhost:$EZBEQ_PORT  (Ctrl+C to detach from logs)"
    echo
    "${COMPOSE[@]}" logs -f
else
    echo
    echo "Running at http://localhost:$EZBEQ_PORT"
    echo "Logs: scripts/run-local --logs   |   Stop: scripts/run-local --stop"
fi
